    taskName = "{{ entry.taskName }}",
    mainClassName = "{{ entry.mainClass }}",
    descriptionText = "{{ entry.description }}",
    {% if entry.jvmArgs %}
    jvmArgsList = listOf(
        {% for arg in entry.jvmArgs %}
        "{{ arg }}"{% if not loop.last %},{% endif %}
        {% endfor %}
    ),
    {% endif %}
)

{% endfor %}
