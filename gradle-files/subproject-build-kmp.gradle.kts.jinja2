plugins.withId("org.jetbrains.dokka") {
    afterEvaluate {
        extensions.findByType(DokkaExtension::class)?.apply {
            moduleName.set("{{ project_name }}")
            dokkaPublications.named("html").configure {
                suppressInheritedMembers.set(true)
                failOnWarning.set(true)
            }

            dokkaSourceSets.configureEach {
                if (name == "commonMain") {
                    val dokkaModuleFile = file("docs/dokka-module.md")
                    if (dokkaModuleFile.exists()) {
                        includes.from(dokkaModuleFile)
                    }
                }
                {% for source_set_name in dokka_suppress_source_sets %}
                if (name == "{{ source_set_name }}") {
                    suppress.set(true)
                }
                {% endfor %}
                {% if has_dokka_source_link %}
                sourceLink {
                    localDirectory.set(file("src"))
                    remoteUrl("{{ dokka_source_link_remote_url }}")
                    remoteLineSuffix.set("#L")
                }
                {% endif %}
            }

            pluginsConfiguration.named(DokkaHtmlPluginParameters.DOKKA_HTML_PARAMETERS_NAME).configure {
                (this as DokkaHtmlPluginParameters).footerMessage.set("(c) {{ company_legal_name }}")
            }
        }
