{% if is_kotlin_compiler_plugin_project and compiler_plugin_publish_version_with_kotlin %}
fun compilerPluginPublicationVersion(baseVersion: String, kotlinVersion: String): String {
    val snapshotSuffix = "+dev-SNAPSHOT"
    return if (baseVersion.endsWith(snapshotSuffix)) {
        "${baseVersion.removeSuffix(snapshotSuffix)}-kotlin-$kotlinVersion$snapshotSuffix"
    } else {
        "$baseVersion-kotlin-$kotlinVersion"
    }
}
