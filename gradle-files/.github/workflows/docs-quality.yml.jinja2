name: Docs Quality

on:
  pull_request:
  push:
    branches:
      - "**"
    tags:
      - "v*"

jobs:
  docs-quality:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Setup Java
        uses: actions/setup-java@v5
        with:
          distribution: corretto
          java-version: "{{ java_version }}"
          cache: gradle

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

{% if needs_android %}
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
{% endif %}
      - name: Ensure Gradle wrapper is executable
        run: chmod +x ./gradlew

      - name: Install markdown docs tooling
        run: python3 -m pip install --disable-pip-version-check mkdocs==1.6.1

      - name: Build and generate Dokka docs
        run: {{ docs_build_command }}

      - name: Build markdown docs site
        run: python3 scripts/build_pages_markdown_site.py --output-dir "$RUNNER_TEMP/pages-markdown"
