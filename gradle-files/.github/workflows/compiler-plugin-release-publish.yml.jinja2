name: Release Publish

on:
  push:
    tags:
      - "v*.*.*"
  workflow_dispatch:

permissions:
  contents: write

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  determine-kotlin-matrix:
    runs-on: ubuntu-latest
    outputs:
      kotlin_versions: {% raw %}${{ steps.kotlin_matrix.outputs.kotlin_versions }}{% endraw %}
    steps:
      - name: Checkout
        uses: actions/checkout@v5

      - name: Read supported Kotlin matrix
        id: kotlin_matrix
        run: |
          KOTLIN_VERSIONS="$(python3 - <<'PY'
          import json
          from pathlib import Path

          properties = {}
          for raw_line in Path("gradle.properties").read_text().splitlines():
              line = raw_line.strip()
              if not line or line.startswith("#") or "=" not in line:
                  continue
              key, value = line.split("=", 1)
              properties[key.strip()] = value.strip()

          versions = [value.strip() for value in properties.get("supportedKotlinVersions", "").split(",") if value.strip()]
          if not versions:
              raise SystemExit("supportedKotlinVersions is empty")

          print(json.dumps(versions))
          PY
          )"
          printf 'kotlin_versions=%s\n' "${KOTLIN_VERSIONS}" >> "$GITHUB_OUTPUT"

  publish-core:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Setup Java
        uses: actions/setup-java@v5
        with:
          distribution: corretto
          java-version: "{{ java_version }}"
          cache: gradle

{% if needs_android %}
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
{% endif %}
      - name: Ensure Gradle wrapper is executable
        run: chmod +x ./gradlew

      - name: Assert annotated release tag
        if: github.event_name == 'push'
        run: |
          git fetch --force --tags origin
          TAG_TYPE="$(git for-each-ref "refs/tags/${GITHUB_REF_NAME}" --format='%(objecttype)')"
          test "${TAG_TYPE}" = "tag"

      - name: Validate release version
        run: {{ core_release_validation_command }}

      - name: Match tag to published version
        if: github.event_name == 'push'
        run: |
          EXPECTED_VERSION="${GITHUB_REF_NAME#v}"
          ACTUAL_VERSIONS="$({{ repo_base_version_print_command }})"
          ACTUAL_VERSIONS="$(printf '%s\n' "${ACTUAL_VERSIONS}" | sed '/^[[:space:]]*$/d')"
          UNIQUE_VERSIONS="$(printf '%s\n' "${ACTUAL_VERSIONS}" | sort -u)"
          test "$(printf '%s\n' "${UNIQUE_VERSIONS}" | wc -l | tr -d ' ')" = "1"
          test "${UNIQUE_VERSIONS}" = "${EXPECTED_VERSION}"

      - name: Dry run release build
        if: github.event_name == 'workflow_dispatch'
        run: {{ core_release_build_command }}

      - name: Publish release to Maven Central
        if: github.event_name == 'push'
        env:
          ORG_GRADLE_PROJECT_mavenCentralUsername: {% raw %}${{ secrets.MAVEN_USERNAME }}{% endraw %}
          ORG_GRADLE_PROJECT_mavenCentralPassword: {% raw %}${{ secrets.MAVEN_PASSWORD }}{% endraw %}
          ORG_GRADLE_PROJECT_signingInMemoryKey: {% raw %}${{ secrets.MAVEN_GPG_PRIVATE_KEY }}{% endraw %}
          ORG_GRADLE_PROJECT_signingInMemoryKeyPassword: {% raw %}${{ secrets.MAVEN_GPG_PASSPHRASE }}{% endraw %}
        run: {{ core_release_publish_command }}

{% if has_core_release_bundle_projects %}
      - name: Bundle core GitHub Release assets
        if: github.event_name == 'push'
        run: |
          python3 - <<'PY'
          import hashlib
          import json
          import os
          import zipfile
          from pathlib import Path

          output_dir = Path("build/release-artifacts")
          output_dir.mkdir(parents=True, exist_ok=True)

          repo_name = os.environ["GITHUB_REPOSITORY"].split("/", 1)[1]
          version_label = os.environ["GITHUB_REF_NAME"].removeprefix("v")
          projects = json.loads(r'''{{ core_release_bundle_projects_json }}''')

          for project in projects:
              source_dir = Path(project["sourceDir"])
              if not source_dir.is_dir():
                  raise SystemExit(f"Missing release bundle source directory: {source_dir}")

              files = sorted(path for path in source_dir.rglob("*") if path.is_file())
              if not files:
                  raise SystemExit(f"No release bundle inputs found under {source_dir}")

              bundle_name = f"{repo_name}-{version_label}-{project['assetSlug']}.zip"
              bundle_path = output_dir / bundle_name
              with zipfile.ZipFile(bundle_path, "w", compression=zipfile.ZIP_DEFLATED) as archive:
                  for path in files:
                      archive.write(path, Path(project["archivePrefix"]) / path.relative_to(source_dir))

              hashlib.sha256(bundle_path.read_bytes()).hexdigest()
          PY

      - name: Upload core GitHub Release assets
        if: github.event_name == 'push'
        uses: actions/upload-artifact@v4
        with:
          name: github-release-assets-core
          path: build/release-artifacts/*.zip
{% endif %}

  publish-compiler-plugin:
    needs:
      - determine-kotlin-matrix
      - publish-core
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        kotlin-version: {% raw %}${{ fromJson(needs.determine-kotlin-matrix.outputs.kotlin_versions) }}{% endraw %}
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Setup Java
        uses: actions/setup-java@v5
        with:
          distribution: corretto
          java-version: "{{ java_version }}"
          cache: gradle

{% if needs_android %}
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
{% endif %}
      - name: Ensure Gradle wrapper is executable
        run: chmod +x ./gradlew

      - name: Validate compiler plugin release version
        run: {{ compiler_release_validation_command }}

      - name: Dry run compiler plugin build
        if: github.event_name == 'workflow_dispatch'
        run: {{ compiler_release_build_command }}

      - name: Publish compiler plugin to Maven Central
        if: github.event_name == 'push'
        env:
          ORG_GRADLE_PROJECT_mavenCentralUsername: {% raw %}${{ secrets.MAVEN_USERNAME }}{% endraw %}
          ORG_GRADLE_PROJECT_mavenCentralPassword: {% raw %}${{ secrets.MAVEN_PASSWORD }}{% endraw %}
          ORG_GRADLE_PROJECT_signingInMemoryKey: {% raw %}${{ secrets.MAVEN_GPG_PRIVATE_KEY }}{% endraw %}
          ORG_GRADLE_PROJECT_signingInMemoryKeyPassword: {% raw %}${{ secrets.MAVEN_GPG_PASSPHRASE }}{% endraw %}
        run: {{ compiler_release_publish_command }}

      - name: Bundle compiler GitHub Release assets
        if: github.event_name == 'push'
        env:
          RELEASE_VARIANT_SUFFIX: {% raw %}kotlin-${{ matrix.kotlin-version }}{% endraw %}
        run: |
          python3 - <<'PY'
          import hashlib
          import json
          import os
          import zipfile
          from pathlib import Path

          output_dir = Path("build/release-artifacts")
          output_dir.mkdir(parents=True, exist_ok=True)

          repo_name = os.environ["GITHUB_REPOSITORY"].split("/", 1)[1]
          version_label = os.environ["GITHUB_REF_NAME"].removeprefix("v")
          variant_suffix = os.environ["RELEASE_VARIANT_SUFFIX"]
          projects = json.loads(r'''{{ compiler_release_bundle_projects_json }}''')

          for project in projects:
              source_dir = Path(project["sourceDir"])
              if not source_dir.is_dir():
                  raise SystemExit(f"Missing release bundle source directory: {source_dir}")

              files = sorted(path for path in source_dir.rglob("*") if path.is_file())
              if not files:
                  raise SystemExit(f"No release bundle inputs found under {source_dir}")

              bundle_name = f"{repo_name}-{version_label}-{project['assetSlug']}-{variant_suffix}.zip"
              bundle_path = output_dir / bundle_name
              with zipfile.ZipFile(bundle_path, "w", compression=zipfile.ZIP_DEFLATED) as archive:
                  for path in files:
                      archive.write(path, Path(project["archivePrefix"]) / path.relative_to(source_dir))

              hashlib.sha256(bundle_path.read_bytes()).hexdigest()
          PY

      - name: Upload compiler GitHub Release assets
        if: github.event_name == 'push'
        uses: actions/upload-artifact@v4
        with:
          name: {% raw %}github-release-assets-kotlin-${{ matrix.kotlin-version }}{% endraw %}
          path: build/release-artifacts/*.zip

  github-release:
    if: github.event_name == 'push'
    needs:
      - publish-core
      - publish-compiler-plugin
    runs-on: ubuntu-latest
    steps:
      - name: Download GitHub Release bundle artifacts
        uses: actions/download-artifact@v5
        with:
          path: build/release-artifacts
          pattern: github-release-assets-*
          merge-multiple: true

      - name: Build aggregate GitHub Release assets
        run: |
          python3 - <<'PY'
          import hashlib
          import json
          import os
          import shutil
          import zipfile
          from pathlib import Path

          source_dir = Path("build/release-artifacts")
          asset_paths = sorted(path for path in source_dir.rglob("*.zip"))
          if not asset_paths:
              raise SystemExit("No release bundle artifacts were downloaded")

          output_dir = Path("build/releases")
          output_dir.mkdir(parents=True, exist_ok=True)

          copied_assets = []
          assets = []
          for source_path in asset_paths:
              target_path = output_dir / source_path.name
              shutil.copyfile(source_path, target_path)
              digest = hashlib.sha256(target_path.read_bytes()).hexdigest()
              copied_assets.append(target_path)
              assets.append(
                  {
                      "fileName": target_path.name,
                      "path": str(target_path.resolve()),
                      "sha256": digest,
                      "sizeBytes": target_path.stat().st_size,
                  }
              )

          repo_name = os.environ["GITHUB_REPOSITORY"].split("/", 1)[1]
          version_label = os.environ["GITHUB_REF_NAME"].removeprefix("v")
          aggregate_path = output_dir / f"{repo_name}-{version_label}-all.zip"
          with zipfile.ZipFile(aggregate_path, "w", compression=zipfile.ZIP_DEFLATED) as archive:
              for path in copied_assets:
                  archive.write(path, path.name)

          aggregate_digest = hashlib.sha256(aggregate_path.read_bytes()).hexdigest()
          assets.append(
              {
                  "kind": "aggregate",
                  "fileName": aggregate_path.name,
                  "path": str(aggregate_path.resolve()),
                  "sha256": aggregate_digest,
                  "sizeBytes": aggregate_path.stat().st_size,
              }
          )

          checksums_path = output_dir / "SHA256SUMS"
          checksum_lines = [
              f"{hashlib.sha256(path.read_bytes()).hexdigest()}  {path.name}"
              for path in sorted([*copied_assets, aggregate_path])
          ]
          checksums_path.write_text("\n".join(checksum_lines) + "\n", encoding="utf-8")

          manifest_path = output_dir / "release-manifest.json"
          manifest_path.write_text(
              json.dumps(
                  {
                      "repo": {
                          "name": repo_name,
                          "githubRepo": os.environ["GITHUB_REPOSITORY"],
                          "versionLabel": version_label,
                      },
                      "assets": assets,
                  },
                  indent=2,
              )
              + "\n",
              encoding="utf-8",
          )
          PY

      - name: Publish GitHub Release assets
        uses: softprops/action-gh-release@v2
        with:
          generate_release_notes: true
          files: |
            build/releases/*.zip
            build/releases/release-manifest.json
            build/releases/SHA256SUMS
