name: Snapshot Publish

on:
  push:
    branches:
      - master
  workflow_dispatch:

permissions:
  contents: read

jobs:
  publish:
    if: github.ref_type != 'tag'
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Setup Java
        uses: actions/setup-java@v5
        with:
          distribution: corretto
          java-version: "{{ java_version }}"
          cache: gradle

{% if needs_android %}
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
{% endif %}
      - name: Ensure Gradle wrapper is executable
        run: chmod +x ./gradlew

      - name: Detect snapshot version
        id: snapshot_version
        run: |
          VERSIONS="$({{ snapshot_version_print_command }})"
          VERSIONS="$(printf '%s\n' "${VERSIONS}" | sed '/^[[:space:]]*$/d' | sort -u)"
          test -n "${VERSIONS}"
          printf 'versions<<EOF\n%s\nEOF\n' "${VERSIONS}" >> "$GITHUB_OUTPUT"

          IS_SNAPSHOT=true
          while IFS= read -r version; do
            if [ -n "${version}" ] && ! printf '%s' "${version}" | grep -qE '\+dev-SNAPSHOT$'; then
              IS_SNAPSHOT=false
              break
            fi
          done <<EOF
          ${VERSIONS}
          EOF

          echo "is_snapshot=${IS_SNAPSHOT}" >> "$GITHUB_OUTPUT"

      - name: Skip snapshot publish for release version
        if: github.event_name == 'push' && steps.snapshot_version.outputs.is_snapshot != 'true'
        run: |
          echo "Skipping snapshot publish for non-snapshot version(s):"
          printf '%s\n' "{% raw %}${{ steps.snapshot_version.outputs.versions }}{% endraw %}"

      - name: Publish snapshot to Maven Central
        if: github.event_name == 'workflow_dispatch' || steps.snapshot_version.outputs.is_snapshot == 'true'
        env:
          ORG_GRADLE_PROJECT_mavenCentralUsername: {% raw %}${{ secrets.MAVEN_USERNAME }}{% endraw %}
          ORG_GRADLE_PROJECT_mavenCentralPassword: {% raw %}${{ secrets.MAVEN_PASSWORD }}{% endraw %}
          ORG_GRADLE_PROJECT_signingInMemoryKey: {% raw %}${{ secrets.MAVEN_GPG_PRIVATE_KEY }}{% endraw %}
          ORG_GRADLE_PROJECT_signingInMemoryKeyPassword: {% raw %}${{ secrets.MAVEN_GPG_PASSPHRASE }}{% endraw %}
        run: {{ snapshot_publish_command }}
