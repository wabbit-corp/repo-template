# Generated by app-wabbit-dev setup (repo docs workflow). Do not edit by hand.
name: Docs Quality

on:
  pull_request:
  push:
    branches:
      - "**"
    tags:
      - "v*"
  workflow_dispatch:

jobs:
  docs-quality:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

{% if needs_java %}
      - name: Setup Java
        uses: actions/setup-java@v5
        with:
          distribution: corretto
          java-version: "{{ java_version }}"
          cache: gradle
{% endif %}
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

{% if needs_android %}
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
{% endif %}
{% if needs_dotnet %}
      - name: Setup .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: "{{ dotnet_version }}"
{% endif %}
{% if needs_java %}
      - name: Ensure Gradle wrapper is executable
        run: chmod +x ./gradlew
{% endif %}
      - name: Build repository docs site
        run: python3 scripts/build_repo_docs_site.py --mode quality --output-dir "$RUNNER_TEMP/pages-site"
