# Generated by app-wabbit-dev setup (repo docs workflow). Do not edit by hand.
name: Docs Deploy

on:
  push:
    branches:
      - master
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

{% if needs_java %}
      - name: Setup Java
        uses: actions/setup-java@v5
        with:
          distribution: corretto
          java-version: "{{ java_version }}"
          cache: gradle
{% endif %}
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

{% if needs_android %}
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
{% endif %}
{% if needs_dotnet %}
      - name: Setup .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: "{{ dotnet_version }}"
{% endif %}
{% if needs_java %}
      - name: Ensure Gradle wrapper is executable
        run: chmod +x ./gradlew
{% endif %}
      - name: Configure Pages
        uses: actions/configure-pages@v5

      - name: Build repository docs site
        run: python3 scripts/build_repo_docs_site.py --mode deploy --output-dir "$RUNNER_TEMP/pages-site"

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v4
        with:
          path: {% raw %}${{ runner.temp }}{% endraw %}/pages-site

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: {% raw %}${{ steps.deployment.outputs.page_url }}{% endraw %}
    steps:
      - name: Deploy Pages
        id: deployment
        uses: actions/deploy-pages@v4
