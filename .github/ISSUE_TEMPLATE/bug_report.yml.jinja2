name: Bug report
description: Report a reproducible problem in this repository.
title: "[Bug]: "
labels:
  - bug
body:
  - type: textarea
    id: summary
    attributes:
      label: Summary
      description: What broke?
      placeholder: A concise description of the problem.
    validations:
      required: true
  - type: textarea
    id: reproduction
    attributes:
      label: Reproduction
      description: How can we reproduce it?
      placeholder: Include commands, steps, inputs, and environment details.
    validations:
      required: true
  - type: textarea
    id: expected
    attributes:
      label: Expected behavior
      description: What did you expect to happen instead?
    validations:
      required: true
  - type: textarea
    id: notes
    attributes:
      label: Additional context
      description: Logs, screenshots, related issues, or anything else that helps.
  - type: markdown
    attributes:
      value: |
        For security-sensitive reports, email {{ contact_email }} instead of filing a public issue.
