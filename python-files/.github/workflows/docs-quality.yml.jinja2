name: Docs Quality

on:
  pull_request:
  push:
    branches:
      - "**"
    tags:
      - "v*"

jobs:
  docs-quality:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.13"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          python -m pip install -e . pytest "mkdocs>=1.6,<2.0" "mkdocs-material>=9.6,<9.7" codespell

{% if has_changelog_guard_script %}
      - name: Enforce changelog/docs updates on PRs
        if: github.event_name == 'pull_request'
        run: python scripts/check_changelog_guard.py
{% endif %}
{% if has_generate_api_docs_script %}
      - name: Check generated API docs
        run: python scripts/generate_api_docs.py --check
{% endif %}
{% if has_docs_links_script %}
      - name: Check markdown links
        run: python scripts/check_docs_links.py
{% endif %}
{% if has_docs_snippets_test %}
      - name: Test documentation snippets
        run: python -m pytest -q tests/test_docs_snippets.py
{% endif %}
      - name: Spell check docs
        run: |
          python - <<'PY'
          from pathlib import Path
          import subprocess

          candidates = [Path("README.md"), Path("docs"), Path("CHANGELOG.md"), Path("CONTRIBUTING.md")]
          existing = [str(path) for path in candidates if path.exists()]
          if existing:
              subprocess.run(
                  ["codespell", *existing, "--ignore-words=.codespell-ignore-words.txt"],
                  check=True,
              )
          PY

      - name: Build docs
        run: mkdocs build --strict
